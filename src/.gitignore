# ---- Python build / bytecode ----
__pycache__/
*.py[cod]
*$py.class
*.so

# ---- Packaging / build artifacts ----
build/
dist/
.eggs/
*.egg-info/

# ---- Virtual environments ----
.venv/
venv/
env/
.envrc

# ---- Environment files (keep secrets out of git) ----
.env
.env.*

# ---- Caches & tooling ----
.mypy_cache/
.pytest_cache/
.pyre/
.pytype/
.cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.pybuild/

# ---- Logs & runtime output ----
logs/
*.log
*.out
*.err

# ---- Databases / local data ----
*.sqlite3
*.db
*.db-journal

# ---- IDE / Editor ----
.vscode/
.idea/
*.code-workspace

# ---- OS / Misc ----
.DS_Store
Thumbs.db

# ---- Frontend (if later added) ----
node_modules/
*.tsbuildinfo

# ---- Profiling ----
.prof
.profile
*.pstats

# ---- Jupyter / notebooks ----
.ipynb_checkpoints/

# ---- Hypothesis ----
.hypothesis/

# ---- PDM / pip / wheels ----
pip-wheel-metadata/

