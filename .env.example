# ========================================
# LLM 提供商配置
# ========================================
# 选择要使用的 LLM 提供商: azure_openai, deepseek, kimi, doubao
LLM_PROVIDER=azure_openai

# ========================================
# Azure OpenAI 配置
# ========================================
AZURE_OPENAI_ENDPOINT="https://endpoint"
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-41-2025-04-14-global"
AZURE_OPENAI_MODEL_NAME="gpt-4.1"
AZURE_OPENAI_API_VERSION="2024-12-01-preview"

# ========================================
# DeepSeek 配置
# ========================================
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ========================================
# Kimi (Moonshot) 配置
# ========================================
KIMI_API_KEY=your-kimi-api-key
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ========================================
# 豆包 (Doubao/字节跳动) 配置
# ========================================
DOUBAO_API_KEY=your-doubao-api-key
# 或者使用别名
# BYTEDANCE_API_KEY=your-bytedance-api-key
DOUBAO_MODEL=doubao-pro-4k
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ========================================
# Twitter/Nitter 配置
# ========================================
# Nitter 实例列表，用逗号分隔
NITTER_INSTANCES=https://nitter.net,https://nitter.privacydev.net
# 代理设置 (可选)，例如: http://127.0.0.1:1087
PROXY_URL=

# ========================================
# X (Twitter) API 配置
# ========================================
# 如果配置了 Bearer Token，将优先使用官方 API
# TWITTER_BEARER_TOKEN=
