# ========================================
# 自建开源大模型配置 (Ollama / vLLM / LocalAI 等)
# ========================================
# 模型服务地址 (默认 Ollama 地址)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# 模型名称 (根据你部署的模型修改)
LOCAL_LLM_MODEL=qwen2.5:7b
# API Key (Ollama 不需要，其他服务可能需要)
LOCAL_LLM_API_KEY=not-needed

# ========================================
# Twitter/Nitter 配置
# ========================================
# Nitter 实例列表，用逗号分隔
# nitter.net 已关闭，请使用仍在运行的替代实例
NITTER_INSTANCES=https://xcancel.com,https://nitter.poast.org
# 代理设置 (可选)，例如: http://127.0.0.1:1087
PROXY_URL=

# ========================================
# X (Twitter) API 配置
# ========================================
# 如果配置了 Bearer Token，将优先使用官方 API
# API 失败时（网络不通、429 限流、401 认证失败等）自动 Fallback 到 Playwright/Nitter
# TWITTER_BEARER_TOKEN=your_bearer_token_here

# ========================================
# 系统提示词配置 (可选，不配置则使用代码中的默认值)
# ========================================
# Agent 的基础行为规则（强制执行，用户无法通过界面覆盖）
# BASE_SYSTEM_PROMPT=你是一个Twitter用户行为分析专家。...
# 默认的用户补充提示词（用户可在界面中修改）
# DEFAULT_USER_SYSTEM_PROMPT=你可以通过分析Twitter用户的推文内容来提供深入的用户行为洞察。...
